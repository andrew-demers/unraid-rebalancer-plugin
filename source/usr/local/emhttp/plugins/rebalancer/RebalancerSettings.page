<script>
(function() {
  'use strict';

  var AJAX = '/plugins/rebalancer/include/ajax/';

  // Keep range + number inputs in sync
  var rangeEl = document.getElementById('max-used-range');
  var numEl   = document.getElementById('max-used-num');

  function showToast(msg, type) {
    var t = document.createElement('div');
    t.className = 'toast ' + (type || 'info');
    t.textContent = msg;
    document.getElementById('toast-container').appendChild(t);
    setTimeout(function() { t.remove(); }, 4000);
  }

  window.clearActiveHours = function() {
    document.getElementById('ah-start').value = '';
    document.getElementById('ah-end').value   = '';
  };

  window.saveSettings = function(e) {
    e.preventDefault();
    var btn = document.getElementById('btn-save');
    btn.disabled = true;

    var ahStart = document.getElementById('ah-start').value.trim();
    var ahEnd   = document.getElementById('ah-end').value.trim();
    var ahValue = '';
    if (ahStart && ahEnd) {
      ahValue = ahStart + '-' + ahEnd;
    } else if (ahStart || ahEnd) {
      showToast('Please set both start and end times for Active Hours, or clear both.', 'error');
      btn.disabled = false;
      return false;
    }

    var data = {
      max_used:       numEl.value,
      strategy:       document.getElementById('strategy').value,
      excludes:       document.getElementById('excludes').value,
      active_hours:   ahValue,
      min_free_space: document.getElementById('min-free-space').value,
      bwlimit:        document.getElementById('bwlimit').value,
      copy_timeout:   document.getElementById('copy-timeout').value,
      verify_timeout: document.getElementById('verify-timeout').value,
      lsof_timeout:   document.getElementById('lsof-timeout').value,
    };

    $.post(AJAX + 'save_settings.php', data, function(resp) {
      if (resp.success) {
        showToast('Settings saved successfully', 'success');
      } else {
        showToast('Error: ' + (resp.error || 'Unknown error'), 'error');
      }
    }, 'json').fail(function() {
      showToast('Request failed — check server logs', 'error');
    }).always(function() { btn.disabled = false; });

    return false;
  };

})();
</script>
