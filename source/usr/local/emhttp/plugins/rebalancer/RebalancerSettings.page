$strategy       = $cfg['strategy'];
$excludes       = is_array($cfg['excludes']) ? implode(', ', $cfg['excludes']) : (string)$cfg['excludes'];
$active_hours   = $cfg['active_hours'] ?? '';
$min_free_space = $cfg['min_free_space'] ?? '50G';
$bwlimit        = $cfg['bwlimit'] !== null ? (string)$cfg['bwlimit'] : '';
$copy_timeout   = (int)($cfg['copy_timeout'] ?? 86400);
$verify_timeout = (int)($cfg['verify_timeout'] ?? 28800);
$lsof_timeout   = (int)($cfg['lsof_timeout'] ?? 120);

// Parse active hours into start/end
$ah_start = '';
$ah_end   = '';
if ($active_hours && preg_match('/^(\d{2}:\d{2})-(\d{2}:\d{2})$/', $active_hours, $m)) {
    $ah_start = $m[1];
    $ah_end   = $m[2];
}
